{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "ScreenFellow",
  "description": "__MSG_appDescription__",
  "version": "1.0.0",
  "default_locale": "en",

  "icons": {
    "16":  "icons/ScreenFellow_Logo_16_transparent.png",
    "32":  "icons/ScreenFellow_Logo_32_transparent.png",
    "48":  "icons/ScreenFellow_Logo_48_transparent.png",
    "128": "icons/ScreenFellow_Logo_126_transparent.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ScreenFellow",
    "default_icon": {
      "16":  "icons/ScreenFellow_Logo_16_transparent.png",
      "32":  "icons/ScreenFellow_Logo_32_transparent.png",
      "48":  "icons/ScreenFellow_Logo_48_transparent.png",
      "128": "icons/ScreenFellow_Logo_126_transparent.png"
    }
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "downloads",
    "tabs"
  ],

  "host_permissions": [
    "https://api.lemonsqueezy.com/*",
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/shortcuts.js"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "capture-visible": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Capture visible area"
    },
    "capture-fullpage": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Capture full page"
    },
    "capture-selection": {
      "suggested_key": {
        "default": "Alt+Shift+X"
      },
      "description": "Capture selection"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["editor/editor.html", "lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
